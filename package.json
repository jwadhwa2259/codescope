{
  "name": "codescope",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "build:grammars": "npx tree-sitter build --wasm node_modules/tree-sitter-typescript/typescript && npx tree-sitter build --wasm node_modules/tree-sitter-typescript/tsx && npx tree-sitter build --wasm node_modules/tree-sitter-javascript && npx tree-sitter build --wasm node_modules/tree-sitter-python && mv *.wasm grammars/",
    "copy:grammars": "cp node_modules/tree-sitter-wasms/out/tree-sitter-typescript.wasm node_modules/tree-sitter-wasms/out/tree-sitter-tsx.wasm node_modules/tree-sitter-wasms/out/tree-sitter-javascript.wasm node_modules/tree-sitter-wasms/out/tree-sitter-python.wasm grammars/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "enhanced-resolve": "^5.20.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-traversal": "^0.3.1",
    "graphology-types": "^0.24.8",
    "js-yaml": "^4.1.1",
    "tsconfig-paths": "^4.2.0",
    "web-tree-sitter": "0.25.10",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "latest",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "tree-sitter-cli": "^0.25.10",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-wasms": "^0.1.13",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "brace-expansion": ">=1.1.13"
  }
}
